# Firebase (web client config — obtenlo en Firebase Console > Configuración del proyecto)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Firebase Admin (servidor — usa un secreto, no lo commitees)
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_PROJECT_ID=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Gemini AI
GEMINI_API_KEY=""

# App
APP_URL="http://localhost:3000"
PORT="3000"

# Backend URL (vacío en dev — Vite proxy lo resuelve; en producción pon la URL de Render)
VITE_API_URL=""
# Ejemplo producción: VITE_API_URL="https://elenaos-api.onrender.com"

# CORS — orígenes permitidos en el backend (coma separados)
ALLOWED_ORIGINS="https://elena-os.web.app,http://localhost:5173"

# WhatsApp Business API (Meta) — opcional, Baileys funciona sin esto
META_WA_TOKEN=""
META_PHONE_NUMBER_ID=""
META_WA_VERIFY_TOKEN=""
# Firma HMAC del webhook de WhatsApp (genera uno aleatorio: openssl rand -hex 32)
WHATSAPP_WEBHOOK_SECRET=""
